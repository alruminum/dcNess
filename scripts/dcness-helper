#!/usr/bin/env bash
# dcNess helper wrapper — PYTHONPATH 자동 설정 후 harness.session_state CLI 실행.
#
# 호출자: skill prompt 의 Bash tool. CC slash command bash 환경엔 PYTHONPATH 미설정 →
# `python3 -m harness.session_state ...` 직접 호출 시 ModuleNotFoundError. 본 wrapper 가
# 자기 위치 (BASH_SOURCE) 로부터 plugin root 추출해 PYTHONPATH 에 prepend.
#
# 사용:
#   "${CLAUDE_PLUGIN_ROOT:-$HOME/.claude/plugins/marketplaces/dcness}/scripts/dcness-helper" \
#       begin-run quick
#
# CLAUDE_PLUGIN_ROOT 가 set 안 됐을 때를 대비해 RWH 패턴 (path fallback) 정합.

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUGIN_ROOT="$(dirname "$SCRIPT_DIR")"
export PYTHONPATH="${PLUGIN_ROOT}:${PYTHONPATH:-}"

exec python3 -m harness.session_state "$@"
